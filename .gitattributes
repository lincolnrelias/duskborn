# Unity line ending normalization
# Text files: normalize to LF in repo, checkout as native on each OS
* text=auto

# Unity source files — always LF
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.glsl      text eol=lf
*.vert      text eol=lf
*.frag      text eol=lf
*.asmdef    text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

# Unity asset files — treat as text (YAML) with LF
*.unity     text eol=lf merge=unityyamlmerge
*.prefab    text eol=lf merge=unityyamlmerge
*.asset     text eol=lf merge=unityyamlmerge
*.mat       text eol=lf merge=unityyamlmerge
*.meta      text eol=lf
*.controller text eol=lf
*.anim      text eol=lf
*.overrideController text eol=lf
*.physicMaterial text eol=lf
*.fontsettings text eol=lf
*.guiskin   text eol=lf
*.inputactions text eol=lf

# Binary files — do not diff or merge
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.ai        binary
*.tga       binary
*.tiff      binary
*.bmp       binary
*.exr       binary
*.hdr       binary
*.mp3       binary
*.ogg       binary
*.wav       binary
*.mp4       binary
*.mov       binary
*.avi       binary
*.fbx       binary
*.obj       binary
*.blend     binary
*.ttf       binary
*.otf       binary
*.pdf       binary
*.docx      binary
*.zip       binary
*.dll       binary
*.so        binary
*.dylib     binary
